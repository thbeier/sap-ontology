{
  "@context": {
    "@version": 1.1,
    "sap":  "https://thbeier.github.io/sap-ontology/vocab#",
    "rdf":  "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl":  "http://www.w3.org/2002/07/owl#",
    "xsd":  "http://www.w3.org/2001/XMLSchema#",
    "sh":   "http://www.w3.org/ns/shacl#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "dct":  "http://purl.org/dc/terms/",

    "name":          { "@id": "sap:name",          "@type": "xsd:string" },
    "description":   { "@id": "sap:description",   "@type": "xsd:string" },
    "externalId":    { "@id": "sap:externalId",    "@type": "xsd:string" },
    "processLevel":  { "@id": "sap:processLevel",  "@type": "xsd:string" },
    "bpmnType":      { "@id": "sap:bpmnType",      "@type": "xsd:string" },

    "inScenario":    { "@id": "sap:inScenario",    "@type": "@id" },
    "hasProvenance": { "@id": "sap:hasProvenance", "@type": "@id" },

    "supportedBy":   { "@id": "sap:supportedBy",   "@type": "@id" },
    "realizedBy":    { "@id": "sap:realizedBy",    "@type": "@id" },
    "affects":       { "@id": "sap:affects",       "@type": "@id" },
    "executes":      { "@id": "sap:executes",      "@type": "@id" },
    "owns":          { "@id": "sap:owns",          "@type": "@id" },
    "consumes":      { "@id": "sap:consumes",      "@type": "@id" },
    "authorizedFor": { "@id": "sap:authorizedFor", "@type": "@id" },
    "linkedTo":      { "@id": "sap:linkedTo",      "@type": "@id" },
    "includes":      { "@id": "sap:includes",      "@type": "@id" },
    "carriedBy":     { "@id": "sap:carriedBy",     "@type": "@id" },
    "validates":     { "@id": "sap:validates",     "@type": "@id" },
    "represents":    { "@id": "sap:represents",    "@type": "@id" },
    "targetsScenario":{ "@id": "sap:targetsScenario","@type": "@id" },
    "implementedBy": { "@id": "sap:implementedBy", "@type": "@id" },
    "realizesCapability":{ "@id": "sap:realizesCapability","@type": "@id" },
    "contains":      { "@id": "sap:contains",      "@type": "@id" },
    "followedBy":    { "@id": "sap:followedBy",    "@type": "@id" },
    "produces":      { "@id": "sap:produces",      "@type": "@id" },
    "consumesDoc":   { "@id": "sap:consumesDoc",   "@type": "@id" },
    "routesTo":      { "@id": "sap:routesTo",      "@type": "@id" },
    "hostedOn":      { "@id": "sap:hostedOn",      "@type": "@id" },
    "mastersDataFor":{ "@id": "sap:mastersDataFor","@type": "@id" },
    "transports":    { "@id": "sap:transports",    "@type": "@id" },
    "dependsOn":     { "@id": "sap:dependsOn",     "@type": "@id" },
    "partOf":        { "@id": "sap:partOf",        "@type": "@id" },
    "occupiedBy":    { "@id": "sap:occupiedBy",    "@type": "@id" },
    "memberOf":      { "@id": "sap:memberOf",      "@type": "@id" }
  }
}
