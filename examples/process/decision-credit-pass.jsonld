{
  "@context": "../../context/sap-ontology-context.jsonld",
  "@id": "sap:decision-credit-pass",
  "@type": ["sap:Decision", "sap:DomainInstance"],
  "sap:name": "Credit Pass / Fail",
  "sap:decisionRule": "customer.creditExposure + order.netValue <= customer.creditLimit",
