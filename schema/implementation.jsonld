{
  "@context": "../context/sap-ontology-context.jsonld",
  "@graph": [
    { "@id": "sap:Configuration", "@type": "owl:Class",
      "rdfs:subClassOf": { "@id": "sap:DomainInstance" }, "rdfs:label": "Configuration" },
    { "@id": "sap:Change", "@type": "owl:Class",
      "rdfs:subClassOf": { "@id": "sap:DomainInstance" }, "rdfs:label": "Change" },
    { "@id": "sap:Transport", "@type": "owl:Class",
      "rdfs:subClassOf": { "@id": "sap:DomainInstance" }, "rdfs:label": "Transport" },
    { "@id": "sap:TestCase", "@type": "owl:Class",
      "rdfs:subClassOf": { "@id": "sap:DomainInstance" }, "rdfs:label": "Test Case" },
    { "@id": "sap:Incident", "@type": "owl:Class",
      "rdfs:subClassOf": { "@id": "sap:DomainInstance" }, "rdfs:label": "Incident" },
    { "@id": "sap:Requirement", "@type": "owl:Class",
      "rdfs:subClassOf": { "@id": "sap:DomainInstance" }, "rdfs:label": "Requirement" },

    { "@id": "sap:type",          "@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:string" } },
    { "@id": "sap:scope",         "@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:string" } },
    { "@id": "sap:mutability",    "@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:string" } },
    { "@id": "sap:hasValue",      "@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:string" } },
    { "@id": "sap:status",        "@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:string" } },
    { "@id": "sap:priority",      "@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:string" } },
    { "@id": "sap:requestedBy",   "@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:string" } },
    { "@id": "sap:approvedBy",    "@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:string" } },
    { "@id": "sap:transportId",   "@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:string" } },
    { "@id": "sap:sourceSystemRef","@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:string" } },
    { "@id": "sap:targetSystem",  "@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:string" } },
    { "@id": "sap:releaseStatus", "@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:string" } },
    { "@id": "sap:testType",      "@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:string" } },
    { "@id": "sap:automated",     "@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:boolean" } },
    { "@id": "sap:lastExecutionResult","@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:string" } },
    { "@id": "sap:ticketId",      "@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:string" } },
    { "@id": "sap:title",         "@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:string" } },
    { "@id": "sap:severity",      "@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:string" } },
    { "@id": "sap:reportedAt",    "@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:dateTime" } },
    { "@id": "sap:resolvedAt",    "@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:dateTime" } },
    { "@id": "sap:source",        "@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:string" } },
    { "@id": "sap:acceptanceCriteria","@type": "owl:DatatypeProperty", "rdfs:range": { "@id": "xsd:string" } }
  ]
}
