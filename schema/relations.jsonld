{
  "@context": "../context/sap-ontology-context.jsonld",
  "@graph": [
    { "@id": "sap:supportedBy",    "@type": "owl:ObjectProperty",
      "rdfs:domain": { "@id": "sap:Activity" },
      "rdfs:range":  { "@id": "sap:ApplicationComponent" } },
    { "@id": "sap:realizedBy",     "@type": "owl:ObjectProperty",
      "rdfs:domain": { "@id": "sap:Activity" },
      "rdfs:range":  { "@id": "sap:Configuration" } },
    { "@id": "sap:represents",     "@type": "owl:ObjectProperty",
      "rdfs:domain": { "@id": "sap:BusinessDocument" },
      "rdfs:range":  { "@id": "sap:DataObject" } },
    { "@id": "sap:affects",        "@type": "owl:ObjectProperty",
      "rdfs:domain": { "@id": "sap:Change" },
      "rdfs:range":  { "@id": "sap:Configuration" } },
    { "@id": "sap:impacts",        "@type": "owl:ObjectProperty",
      "rdfs:domain": { "@id": "sap:Change" },
      "rdfs:range":  { "@id": "sap:Activity" },
      "rdfs:comment": "Derived at query time from sap:affects + sap:realizedBy. Not authored directly." },
    { "@id": "sap:linkedTo",       "@type": "owl:ObjectProperty",
      "rdfs:domain": { "@id": "sap:Incident" } },
    { "@id": "sap:executes",       "@type": "owl:ObjectProperty",
      "rdfs:domain": { "@id": "sap:Role" },
      "rdfs:range":  { "@id": "sap:Activity" } },
    { "@id": "sap:owns",           "@type": "owl:ObjectProperty",
      "rdfs:domain": { "@id": "sap:OrgUnit" } },
    { "@id": "sap:consumes",       "@type": "owl:ObjectProperty",
      "rdfs:domain": { "@id": "sap:OrgUnit" },
      "rdfs:range":  { "@id": "sap:ApplicationComponent" } },
    { "@id": "sap:authorizedFor",  "@type": "owl:ObjectProperty",
      "rdfs:domain": { "@id": "sap:Role" },
      "rdfs:range":  { "@id": "sap:Configuration" } },
    { "@id": "sap:realizesCapability","@type": "owl:ObjectProperty",
      "rdfs:domain": { "@id": "sap:Process" },
      "rdfs:range":  { "@id": "sap:Capability" } },
    { "@id": "sap:targetsScenario","@type": "owl:ObjectProperty",
      "rdfs:domain": { "@id": "sap:Requirement" },
      "rdfs:range":  { "@id": "sap:Scenario" } },
    { "@id": "sap:implementedBy",  "@type": "owl:ObjectProperty",
      "rdfs:domain": { "@id": "sap:Requirement" },
      "rdfs:range":  { "@id": "sap:Change" } },
    { "@id": "sap:validates",      "@type": "owl:ObjectProperty",
      "rdfs:domain": { "@id": "sap:TestCase" } },
    { "@id": "sap:inScenario",     "@type": "owl:ObjectProperty",
      "rdfs:range":  { "@id": "sap:Scenario" } },
    { "@id": "sap:hasProvenance",  "@type": "owl:ObjectProperty",
      "rdfs:range":  { "@id": "sap:Provenance" } }
  ]
}
