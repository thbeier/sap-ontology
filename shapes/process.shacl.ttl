@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix sap:  <https://thbeier.github.io/sap-ontology/vocab#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

sap:ProcessShape
    a sh:NodeShape ;
    sh:targetClass sap:Process ;
    sh:node sap:DomainInstanceShape ;
    sh:property [ sh:path sap:name ;         sh:datatype xsd:string ; sh:minCount 1 ] ;
    sh:property [ sh:path sap:processLevel ; sh:datatype xsd:string ; sh:minCount 1 ;
        sh:message "processLevel is required. Use L1_ValueChain / L2_ProcessGroup / L3_Process / L4_SubProcess or a documented client-specific label." ;
        sh:or (
            [ sh:in ( "L1_ValueChain" "L2_ProcessGroup" "L3_Process" "L4_SubProcess" ) ]
            [ sh:pattern "^L\\d+_[A-Za-z]+$" ]
        ) ] ;
    sh:property [ sh:path sap:bpmnType ; sh:datatype xsd:string ;
        sh:in ( "embedded" "call" "event-sub-process" ) ] ;
    sh:property [ sh:path sap:contains ;
        sh:or (
            [ sh:class sap:Process ]
            [ sh:class sap:Activity ]
        ) ] ;
    sh:property [ sh:path sap:realizesCapability ; sh:class sap:Capability ] .

sap:ActivityShape
    a sh:NodeShape ;
    sh:targetClass sap:Activity ;
    sh:node sap:DomainInstanceShape ;
    sh:property [ sh:path sap:name ;            sh:datatype xsd:string ; sh:minCount 1 ] ;
    sh:property [ sh:path sap:isAutomated ;     sh:datatype xsd:boolean ] ;
    sh:property [ sh:path sap:transactionCode ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:message "transactionCode is the canonical SAP T-code executing this Activity (e.g. VA01). Variant T-codes belong in description, not as additional transactionCode values." ;
        sh:pattern "^[A-Z][A-Z0-9_./-]+$" ] ;
    sh:property [ sh:path sap:supportedBy ; sh:class sap:ApplicationComponent ] ;
    sh:property [ sh:path sap:realizedBy ;  sh:class sap:Configuration ] .

sap:EventShape
    a sh:NodeShape ;
    sh:targetClass sap:Event ;
    sh:node sap:DomainInstanceShape ;
    sh:property [ sh:path sap:name ;      sh:datatype xsd:string ; sh:minCount 1 ] ;
    sh:property [ sh:path sap:eventType ; sh:datatype xsd:string ;
        sh:in ( "start" "intermediate" "end" "message" "timer" "signal" ) ] .

sap:DecisionShape
    a sh:NodeShape ;
    sh:targetClass sap:Decision ;
    sh:node sap:DomainInstanceShape ;
    sh:property [ sh:path sap:name ;         sh:datatype xsd:string ; sh:minCount 1 ] ;
    sh:property [ sh:path sap:decisionRule ; sh:datatype xsd:string ; sh:minCount 1 ;
        sh:message "Every Decision must declare its branching rule as a human-readable expression in decisionRule (e.g. 'credit_score >= 600' or 'order_value > approval_threshold')." ] ;
    sh:property [ sh:path sap:routesTo ;     sh:class sap:Activity ; sh:minCount 1 ;
        sh:message "Every Decision must route to at least one Activity (the gateway's onward path). Branching is expressed by multiple routesTo edges." ] .

sap:BusinessDocumentShape
    a sh:NodeShape ;
    sh:targetClass sap:BusinessDocument ;
    sh:node sap:DomainInstanceShape ;
    sh:property [ sh:path sap:name ; sh:datatype xsd:string ; sh:minCount 1 ] ;
    sh:property [ sh:path sap:represents ; sh:class sap:DataObject ] .
